# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/digital-life-lessons-ai

# Firebase Admin SDK (path to your service account key JSON file)
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=./firebase-service-account-key.json

# Client URL (for Stripe redirect URLs)
CLIENT_URL=http://localhost:5173

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
